# Copy to .env and fill in from Supabase → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
#
# Only names starting with VITE_ are exposed to the browser (Vite).

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Optional; some tooling may reference the project ref:
VITE_SUPABASE_PROJECT_ID=
#
# If you use non-VITE_ duplicates (e.g. SUPABASE_URL) for scripts or docs,
# keep them only in your local .env, not in git.
